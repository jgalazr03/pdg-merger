{
  "name": "react-spring-visualizer-base",
  "character": "Retro / neo-brutalista, claro y técnico. Tipografía monoespaciada, bloques de color plano, bordes navy gruesos, esquinas suaves. Sin sombras difusas ni blur.",
  "color": {
    "bg":        { "value": "#fef6e4", "role": "fondo de página" },
    "surface":   { "value": "#f3d2c1", "role": "tarjetas / paneles / barras" },
    "ink":       { "value": "#001858", "role": "texto principal y todos los bordes" },
    "accent":    { "value": "#0000ee", "role": "links, estados activos, foco de marca" },
    "muted":     { "value": "#aaaaaa", "role": "texto secundario / placeholders" },
    "highlight": { "value": "#8bd3dd", "role": "relleno de acento (cian)" },
    "cta":       { "value": "#f582ae", "role": "CTA / destructivo (rosa)" }
  },
  "typography": {
    "family": "Roboto Mono",
    "weights": [400, 500, 700],
    "scale": {
      "h1": { "size": "3rem", "weight": 700 },
      "h2": { "size": "24px", "weight": 700 },
      "h3": { "size": "18px", "weight": 700 },
      "lg": { "size": "20px", "weight": 400 },
      "md": { "size": "16px", "weight": 400 },
      "sm": { "size": "14px", "weight": 400 }
    },
    "lineHeight": { "body": 1.5, "heading": 1.1 },
    "rule": "Una sola familia (mono). Jerarquía por tamaño/peso/color, nunca mezclando fuentes."
  },
  "spacing": { "base": 5, "scale": [5, 10, 15, 20, 25, 30, 40, 60], "rule": "Todo múltiplo de 5px." },
  "radius": { "default": "5px", "large": "20px" },
  "border": { "control": "3px solid ink", "panel": "4px solid ink" },
  "motion": { "duration": "150-200ms", "ease": "cubic-bezier(0.4,0,0.2,1)", "note": "Interacciones físicas con react-spring opcionales." },
  "layout": { "maxWidth": "1000px", "grid": "5px" }
}
